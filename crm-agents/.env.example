# ── Google Gemini API ─────────────────────────────────────────────────────────
# Get your free API key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Optional: override the default Gemini model
# GEMINI_MODEL=gemini-2.0-flash          ← default (fast, available on v1beta)
# GEMINI_MODEL=gemini-1.5-flash          ← slightly older, also available
# GEMINI_MODEL=gemini-1.5-pro            ← higher quality, slower

# Optional: GCP project (only needed for Vertex AI — not required for API key auth)
# GCP_PROJECT=my-gcp-project-id
